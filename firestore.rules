rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'senjayakuswara6@gmail.com' ||
        request.auth.uid == 'K8or1fdblAOY5Nc7PQxVNrQIX872'
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Student Validation - Relaxed for troubleshooting
    function isValidStudent(data) {
      return data.name is string && 
             data.nisn is string && 
             data.status in ['LULUS', 'TIDAK LULUS'] &&
             data.subjects is list;
    }

    // Subject Validation - Hardened
    function isValidSubject(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category in ['UMUM', 'PILIHAN', 'MULOK'] &&
             data.className is string && data.className.size() <= 50 &&
             (data.order == null || data.order is int);
    }

    // Match Rules
    match /students/{studentId} {
      allow get, list: if true; 
      allow write: if isAdmin() && isValidId(studentId) && isValidStudent(incoming());
      allow delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidId(subjectId) && isValidSubject(incoming());
      allow update: if isAdmin() && isValidSubject(incoming());
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
